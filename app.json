{
  "expo": {
    "name": "Kairos",
    "slug": "kairos",
    "scheme": "kairos-dev-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          // "image": "./assets/images/splash.png",
          // "resizeMode": "contain",
          "backgroundColor": "#1a0f2e"
        }
      ],
      "expo-font"
    ],

    "android": {
      "package": "com.olateju.kairos",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a0f2e"
      },
      "edgeToEdgeEnabled": true
    },

    "ios": {
      "supportsTablet": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "9a6c6d34-60a6-42ed-9a46-f3364bc882f1"
      }
    }
  }
}
